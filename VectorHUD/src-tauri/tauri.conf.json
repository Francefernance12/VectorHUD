{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vectorhud",
  "version": "1.1.2",
  "identifier": "com.fernando-arias.vectorhud",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vectorhud",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://openrouter.ai https://api.notion.com https://api.groq.com https://api.openai.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$PICTURE/VectorHUD/**/*",
          "C:/Users/*/OneDrive/Pictures/VectorHUD/**/*",
          "C:/Users/*/Pictures/VectorHUD/**/*"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Francefernance12/VectorHUD/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExMThBNkJBQTY4NjVEMEIKUldRTFhZYW11cVlZb1IvUW90NDVLVCtCUit6a2UxSXJ3NGZKSG53Tm90TzFPTzd2VFJjZGFiMjYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "externalBin": [
      "ffmpeg"
    ],
    "resources": [
      "PresentMon64.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
