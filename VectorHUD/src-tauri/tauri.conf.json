{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vectorhud",
  "version": "1.0.0",
  "identifier": "com.fernando-arias.vectorhud",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vectorhud",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ipc: http://ipc.localhost https://openrouter.ai https://api.notion.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["$PICTURE/VectorHUD/**/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Francefernance12/VectorHUD/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDMkRFRTQwOUM2OTFDMUEKUldRYUhHbWNRTzR0dkV2ZmgzUWNQeFJzVDdOd0VRZWVJZThVcnhqMWRSK1NFcTQ0NFkvaXdYelQK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "resources": [
      "PresentMon64.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
